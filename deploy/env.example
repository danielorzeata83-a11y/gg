# ── On-chain ──────────────────────────────────────────────────────────────
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
POLYGONSCAN_API_KEY=

# ── Trading ───────────────────────────────────────────────────────────────
BANKROLL_USDC=1000
BOT_MODE=paper
# Set to "yes" only when ready for real money
I_UNDERSTAND_REAL_MONEY=no

# ── Dashboard auth ────────────────────────────────────────────────────────
# Generate secret key: python3 -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=REPLACE_WITH_RANDOM_64_CHAR_HEX
DASHBOARD_USER=admin
DASHBOARD_PASS=REPLACE_WITH_STRONG_PASSWORD

# ── File paths (defaults; override only if needed) ────────────────────────
LEDGER_PATH=ledger.jsonl
WATCHLIST_PATH=alpha_wallets.json
SIGNALS_PATH=signals.jsonl
